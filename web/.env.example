# BookMe Web environment template
# Copy this file to .env.local and replace placeholders.

# App
NEXT_PUBLIC_APP_NAME=BookMe
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (dev)
NEXT_PUBLIC_FIREBASE_API_KEY_DEV=your_dev_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_DEV=your_dev_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID_DEV=your_dev_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV=your_dev_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_DEV=your_dev_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID_DEV=your_dev_app_id

# Firebase (prod)
NEXT_PUBLIC_FIREBASE_API_KEY_PROD=your_prod_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_PROD=your_prod_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID_PROD=your_prod_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_PROD=your_prod_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_PROD=your_prod_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID_PROD=your_prod_app_id

# Stripe (optional for Day 0)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
