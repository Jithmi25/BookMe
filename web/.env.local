# Local development values for BookMe Web.
# Keep this file private. Do not commit real secrets.

# App
NEXT_PUBLIC_APP_NAME=BookMe
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (dev)
NEXT_PUBLIC_FIREBASE_API_KEY_DEV=replace_me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_DEV=replace_me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID_DEV=replace_me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_DEV=replace_me.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_DEV=replace_me
NEXT_PUBLIC_FIREBASE_APP_ID_DEV=replace_me

# Firebase (prod)
NEXT_PUBLIC_FIREBASE_API_KEY_PROD=replace_me
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_PROD=replace_me.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID_PROD=replace_me
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_PROD=replace_me.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_PROD=replace_me
NEXT_PUBLIC_FIREBASE_APP_ID_PROD=replace_me

# Stripe (optional for Day 0)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_me
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
